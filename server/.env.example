# Copy to .env for local dev. In production (hosting), set these as env vars.
PORT=4000

# Secret used to sign login tokens. MUST be a long random string in production.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-this-to-a-long-random-string

# Where the SQLite database file lives. In production, point this at a
# persistent disk (e.g. /data/scaylr.db) so data survives restarts/redeploys.
# Leave unset for local dev (defaults to server/db/scaylr.db).
# DB_PATH=/data/scaylr.db

# Anthropic API key for AI features (Lead Intelligence + Call Note Assistant).
# Get yours at https://console.anthropic.com
ANTHROPIC_API_KEY=your-key-here
